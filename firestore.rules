rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function circleExists(circleId) {
      return exists(/databases/$(database)/documents/circles/$(circleId));
    }

    function isCircleParticipant(circleId) {
      return isSignedIn()
        && circleExists(circleId)
        && request.auth.uid in get(/databases/$(database)/documents/circles/$(circleId)).data.players;
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    match /circles/{circleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if false;
    }

    match /chats/{circleId}/messages/{messageId} {
      allow read: if isCircleParticipant(circleId);
      allow create: if isCircleParticipant(circleId)
        && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false;
    }

    match /ratings/{ratingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
